# sw.js : jamais en cache HTTP → le navigateur vérifie toujours la nouvelle version
/sw.js
  Cache-Control: no-store, no-cache, must-revalidate

# manifest.json : idem
/manifest.json
  Cache-Control: no-store, no-cache, must-revalidate

# index.html : toujours frais
/index.html
  Cache-Control: no-store, no-cache, must-revalidate

/
  Cache-Control: no-store, no-cache, must-revalidate

# app.js : cache long — l'URL change à chaque build (app.js?v=<hash de contenu>,
# généré par scripts/build.js), donc immutable est sûr.
/app.js
  Cache-Control: public, max-age=31536000, immutable

# styles.css : même mécanique que app.js (externalisé du HTML le 2026-07-15,
# référencé styles.css?v=<hash de contenu> par scripts/build.js).
/styles.css
  Cache-Control: public, max-age=31536000, immutable

# Icônes PWA : quasi immuables — 7 jours de cache (elles étaient re-validées à
# chaque visite faute de règle, une requête réseau inutile par icône).
/icon-192.png
  Cache-Control: public, max-age=604800
/icon-512.png
  Cache-Control: public, max-age=604800

